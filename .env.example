# Franmarine Project Portal API — environment template
# Copy to .env and fill in. .env is git-ignored.

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/projectportal
# In production (Render) SSL is on automatically. For a managed PG that uses a
# self-signed cert set DATABASE_SSLMODE=no-verify.
# DATABASE_SSLMODE=no-verify
# Optional pool size override (default 30; 5 in test).
# DB_POOL_MAX=30

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (CORS allowlist + any links). In dev the Vite proxy makes the
# cookie same-origin, so this is mainly for production.
CLIENT_URL=http://localhost:5173

# Authenticated API rate limit (generous; auth/login is limited separately).
API_RATE_LIMIT_MAX=10000
API_RATE_LIMIT_WINDOW_MS=900000

# Media uploads. Bytes are stored in Postgres (bytea); this only caps size.
MAX_FILE_SIZE=10485760

# Demo seed password for the one-user-per-role accounts (see config/seed.js).
# Only used to (idempotently) seed demo logins; never log this in production.
SEED_PASSWORD=Password123
