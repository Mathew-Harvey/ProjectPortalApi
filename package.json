{
  "name": "projectportal-api",
  "version": "1.0.0",
  "description": "Franmarine Project Portal API — marine structural remediation delivery portal",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "db:migrate": "node config/migrate.js",
    "db:seed": "node config/seed.js",
    "build": "npm test && npm run db:migrate && npm run db:seed"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.7",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
